# Copy to .streamlit/secrets.toml (gitignored) for local runs.
# On Streamlit Cloud, paste these into Settings -> Secrets instead.
#
# NEVER commit the real secrets.toml.

OPENROUTER_API_KEY = "sk-or-v1-..."

# Any OpenRouter model with tool-calling support.
AIP_MODEL = "anthropic/claude-sonnet-4.5"

# Google Sheet that stores per-response feedback. Optional: without it, feedback
# saves to a local CSV and will NOT survive a Streamlit Cloud restart.
AIP_SHEET_ID = ""

# Service-account JSON, as a single-line string. Share the Sheet with this
# account's client_email (Editor) or appends will fail.
GOOGLE_SERVICE_ACCOUNT_JSON = ""
